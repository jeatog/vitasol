    "aprender.que_es_b1" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "An essential nutrient the body produces when skin is exposed to sunlight."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Nutriente esencial que el cuerpo produce al exponer la piel a la luz solar."
          }
        }
      }
    },
    "aprender.que_es_b2" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Essential for calcium absorption and maintaining strong bones."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Fundamental para la absorción de calcio y el mantenimiento de huesos fuertes."
          }
        }
      }
    },
    "aprender.que_es_b3" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Regulates the immune system and plays a key role in mental health."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Regula el sistema inmunológico y tiene un papel clave en la salud mental."
