          "stringUnit" : {
            "state" : "translated",
            "value" : "🧠  Helps fight depression"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "🧠  Ayuda a combatir la depresión"
          }
        }
