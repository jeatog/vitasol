    "aprender.beneficios_b1" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "🦷  Strengthens bones and teeth"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "🦷  Fortalece huesos y dientes"
          }
        }
      }
    },
    "aprender.beneficios_b2" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "🛡️  Boosts the immune system"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "🛡️  Mejora el sistema inmunológico"
          }
        }
      }
    },
    "aprender.beneficios_b3" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "🧠  Helps fight depression"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "🧠  Ayuda a combatir la depresión"
          }
        }
      }
    },
    "aprender.beneficios_b4" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "❤️  Reduces cardiovascular disease risk"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "❤️  Reduce el riesgo de enfermedades cardíacas"
          }
        }
      }
    },
    "aprender.beneficios_b5" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "🧬  Improves cognitive function"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
