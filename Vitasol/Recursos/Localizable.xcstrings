          }
        }
      }
    },
    "aprender.beneficios_titulo" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Health Benefits"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Beneficios para la Salud"
          }
        }
      }
    },
    "aprender.consejos_b1" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "🌅  Take advantage of morning hours, even in winter"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "🌅  Aprovecha las horas de mañana, incluso en invierno"
          }
        }
      }
    },
    "aprender.consejos_b2" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "🦵  Expose arms, legs, or back — not just your face"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "🦵  Expón brazos, piernas o espalda — no solo el rostro"
          }
        }
      }
    },
    "aprender.consejos_b3" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "⚠️  Be careful with sensitive skin or a history of skin cancer"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "⚠️  Ten cuidado si tienes piel sensible o antecedentes de cáncer de piel"
          }
        }
      }
    },
    "aprender.consejos_b4" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "🤝  Combine it with outdoor physical activity"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "🤝  Combínalo con actividad física al aire libre"
          }
        }
      }
    },
    "aprender.consejos_b5" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "📊  Use the app to track your sun exposure"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "📊  Usa la app para llevar seguimiento de tu exposición"
          }
        }
      }
    },
    "aprender.consejos_titulo" : {
      "localizations" : {
